# ----------------------------------------------------------------------------
# DirectParé — Variables d'environnement
# Copiez ce fichier en .env.local et renseignez les valeurs.
# Sur Vercel : Project Settings → Environment Variables.
# ----------------------------------------------------------------------------

# IA Gemini (utilisée par la route serveur /api/analyze-transaction).
# Clé gardée côté serveur uniquement (pas de préfixe NEXT_PUBLIC_).
GEMINI_API_KEY=

# Supabase (base de données + authentification OTP). Étape suivante.
# NEXT_PUBLIC_ = exposé au navigateur (URL et clé anon, prévues pour l'être).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Clé service_role : SERVEUR UNIQUEMENT, ne jamais préfixer par NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=
